<Page x:Class="TutorTest.Pages.ServiceListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TutorTest.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ServiceListPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="59*"/>
            <RowDefinition Height="332*"/>
            <RowDefinition Height="59*"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="1" Margin="5" HorizontalContentAlignment="Center" HorizontalScrollBarVisibility="Disabled" >
            <WrapPanel x:Name="ServiceWp">

            </WrapPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10">
            <Button x:Name="AddBtn">Добавить</Button>
            <Button></Button>
        </StackPanel>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock>Сортировка</TextBlock>
            <ComboBox x:Name="SortCb" SelectionChanged="SortCb_SelectionChanged">
                <ComboBoxItem>По умолчанию</ComboBoxItem>
                <ComboBoxItem>По возрастанию</ComboBoxItem>
                <ComboBoxItem>По убыванию</ComboBoxItem>
            </ComboBox>
        </StackPanel>
    </Grid>
</Page>
